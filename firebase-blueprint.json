{
  "entities": {
    "Session": {
      "title": "Session",
      "description": "A jury evaluation session for a specific prompt.",
      "type": "object",
      "properties": {
        "prompt": { "type": "string", "description": "The input prompt being evaluated." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "status": { "type": "string", "enum": ["pending", "generating", "evaluating", "completed"], "description": "Current status of the session." }
      },
      "required": ["prompt", "createdAt", "status"]
    },
    "Response": {
      "title": "Response",
      "description": "An AI-generated response to the prompt.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The content of the response." },
        "modelId": { "type": "string", "description": "The ID or name of the model that generated this." },
        "userScore": { "type": "integer", "description": "Optional score given by the human user." },
        "finalScore": { "type": "number", "description": "Aggregate score from judges and user." }
      },
      "required": ["text", "modelId"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "A judge's evaluation of a specific response.",
      "type": "object",
      "properties": {
        "judgeId": { "type": "string", "enum": ["logic", "clarity", "strict", "helpful"], "description": "Identity of the AI judge." },
        "score": { "type": "integer", "description": "Score assigned (1-10)." },
        "justification": { "type": "string", "description": "Reasoning behind the score." }
      },
      "required": ["judgeId", "score", "justification"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Root collection for evaluation sessions."
    },
    "/sessions/{sessionId}/responses/{responseId}": {
      "schema": "Response",
      "description": "responses generated for the session."
    },
    "/sessions/{sessionId}/responses/{responseId}/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Judge evaluations for a response."
    }
  }
}
